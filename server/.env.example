# 服务器端口（Railway 自动设置，本地默认 3001）
PORT=3001

# MySQL 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=personality_test

# JWT 认证
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# 开发模式（设为 false 启用微信正式登录）
DEV_MODE=true

# 微信小程序配置（在微信公众平台获取）
WX_APPID=your_appid
WX_SECRET=your_secret
