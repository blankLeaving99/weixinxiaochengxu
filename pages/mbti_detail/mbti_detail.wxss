.page-wrap {
  min-height: 100vh;
  background: #f3f4f6;
  padding: 24rpx;
  box-sizing: border-box;
}

.empty {
  background: #fff;
  border-radius: 24rpx;
  padding: 80rpx 40rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.empty-emoji {
  font-size: 120rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1f2937;
  display: block;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #6b7280;
  display: block;
  margin-bottom: 40rpx;
}

.header-card {
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.header-emoji {
  font-size: 100rpx;
  display: block;
  margin-bottom: 16rpx;
}

.header-type {
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}

.header-nickname {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1f2937;
  display: block;
  margin-bottom: 16rpx;
}

.card-text {
  font-size: 28rpx;
  color: #374151;
  line-height: 1.8;
  display: block;
}

.love-card {
  border-left: 6rpx solid #ec4899;
}

.career-card {
  border-left: 6rpx solid #3b82f6;
}

.trait-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.trait-item {
  display: flex;
  align-items: center;
}

.trait-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.trait-text {
  font-size: 28rpx;
  color: #374151;
  flex: 1;
}

.btn {
  border-radius: 16rpx;
  padding: 26rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  width: 100%;
  box-sizing: border-box;
  margin-top: 20rpx;
}

.btn::after { border: none; }

.btn-primary {
  background: linear-gradient(135deg, #7c3aed, #5b21b6);
  color: #fff;
}

.btn-secondary {
  background: #f3f4f6;
  color: #374151;
}
