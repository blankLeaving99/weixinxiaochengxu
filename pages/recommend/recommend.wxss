.page-wrap {
  min-height: 100vh;
  background: #f3f4f6;
  padding: 24rpx;
  box-sizing: border-box;
}

/* 空状态 */
.empty {
  background: #fff;
  border-radius: 24rpx;
  padding: 80rpx 40rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.empty-emoji {
  font-size: 120rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1f2937;
  display: block;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #6b7280;
  display: block;
  margin-bottom: 40rpx;
}

/* 头部卡片 */
.header-card {
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}

.header-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1f2937;
  display: block;
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 24rpx;
  color: #6b7280;
  display: block;
  margin-bottom: 20rpx;
}

/* 运势卡片 */
.fortune-card {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
}

.fortune-grid {
  display: flex;
  gap: 16rpx;
  margin: 20rpx 0;
}

.fortune-item {
  flex: 1;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 12rpx;
  padding: 16rpx;
  text-align: center;
}

.fortune-label {
  font-size: 22rpx;
  color: #92400e;
  display: block;
  margin-bottom: 4rpx;
}

.fortune-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #78350f;
  display: block;
}

.fortune-advice {
  font-size: 26rpx;
  color: #92400e;
  display: block;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 12rpx;
  padding: 16rpx;
  line-height: 1.6;
}

/* 推荐列表 */
.rec-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.rec-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.rec-item:last-child {
  border-bottom: none;
}

.rec-num {
  width: 40rpx;
  height: 40rpx;
  background: #f3e8ff;
  color: #7c3aed;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: bold;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.rec-text {
  font-size: 28rpx;
  color: #374151;
  flex: 1;
}

/* 按钮 */
.btn {
  border-radius: 16rpx;
  padding: 26rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  width: 100%;
  box-sizing: border-box;
}

.btn::after { border: none; }

.btn-primary {
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: #fff;
}
