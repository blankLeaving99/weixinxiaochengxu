.page-wrap {
  background: #f3f4f6;
  min-height: 100vh;
  padding: 24rpx 24rpx 60rpx;
  box-sizing: border-box;
}

/* 顶部卡片 */
.header-card {
  border-radius: 20rpx;
  padding: 36rpx 32rpx 32rpx;
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}

.header-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
  display: block;
  margin-bottom: 20rpx;
}

.progress-wrap {
  background: rgba(255, 255, 255, 0.3);
  border-radius: 8rpx;
  height: 10rpx;
  overflow: hidden;
}

.progress-bar {
  background: #fff;
  height: 10rpx;
  border-radius: 8rpx;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 综合分析 */
.analysis-card {
  padding: 28rpx 32rpx;
}

.section-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #7c3aed;
  letter-spacing: 2rpx;
  display: block;
  margin-bottom: 16rpx;
}

.analysis-text {
  font-size: 28rpx;
  color: #374151;
  line-height: 1.8;
  display: block;
  white-space: pre-line;
}

/* 结果条目 */
.result-item {
  padding: 28rpx 32rpx;
}

.item-top {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.item-icon {
  font-size: 44rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
}

.item-title {
  font-size: 30rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 6rpx;
}

.item-tag {
  font-size: 24rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  display: inline-block;
}

.item-arrow {
  font-size: 40rpx;
  color: #d1d5db;
  font-weight: 300;
}

.item-desc {
  font-size: 27rpx;
  color: #6b7280;
  line-height: 1.55;
  display: block;
  padding-left: 62rpx;
}

/* 空状态 */
.result-empty {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  opacity: 0.65;
}

.empty-icon {
  font-size: 40rpx;
  margin-right: 18rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #6b7280;
  flex: 1;
}
