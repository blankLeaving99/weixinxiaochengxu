.page-wrap {
  min-height: 100vh;
  background: #f3f4f6;
  padding: 24rpx;
  box-sizing: border-box;
}

/* 介绍页 */
.intro-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.intro-emoji {
  font-size: 120rpx;
  display: block;
  margin-bottom: 20rpx;
}

.intro-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1f2937;
  display: block;
  margin-bottom: 12rpx;
}

.intro-desc {
  font-size: 28rpx;
  color: #6b7280;
  display: block;
  margin-bottom: 40rpx;
}

.intro-features {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-bottom: 40rpx;
}

.intro-feature {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.feature-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.feature-text {
  font-size: 24rpx;
  color: #6b7280;
}

/* 答题页 */
.progress-wrap {
  background: #e5e7eb;
  border-radius: 10rpx;
  height: 12rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.progress-bar {
  background: linear-gradient(90deg, #f59e0b, #f97316);
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.3s;
}

.quiz-count {
  font-size: 24rpx;
  color: #9ca3af;
  display: block;
  text-align: center;
  margin-bottom: 24rpx;
}

.question-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.question-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #1f2937;
  line-height: 1.6;
  display: block;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.option-item:active {
  background: #fffbeb;
  transform: scale(0.98);
}

.color-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.option-text {
  font-size: 28rpx;
  color: #374151;
  flex: 1;
}

/* 结果页 */
.result-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.result-emoji {
  font-size: 100rpx;
  display: block;
  margin-bottom: 16rpx;
}

.result-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #1f2937;
  display: block;
  margin-bottom: 20rpx;
}

.result-desc {
  font-size: 28rpx;
  color: #374151;
  line-height: 1.8;
  display: block;
  margin-bottom: 30rpx;
}

.traits-wrap {
  text-align: left;
  padding-top: 20rpx;
  border-top: 2rpx solid #f3f4f6;
}

.traits-title {
  font-size: 26rpx;
  color: #9ca3af;
  display: block;
  margin-bottom: 16rpx;
}

.traits {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.trait-tag {
  background: #f3e8ff;
  border-radius: 20rpx;
  padding: 8rpx 20rpx;
}

.trait-text {
  font-size: 24rpx;
  color: #7c3aed;
}

.btn-group {
  margin-top: 30rpx;
}

.btn {
  border-radius: 16rpx;
  padding: 26rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 16rpx;
}

.btn::after { border: none; }

.btn-primary {
  background: linear-gradient(135deg, #f59e0b, #f97316);
  color: #fff;
}

.btn-secondary {
  background: #f3f4f6;
  color: #374151;
}
