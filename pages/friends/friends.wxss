.page-wrap {
  background: #f3f4f6;
  min-height: 100vh;
  padding: 24rpx 24rpx 60rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #7c3aed;
  display: block;
  margin-bottom: 16rpx;
}

.flex { flex: 1; }

.head-row {
  display: flex;
  align-items: center;
}

.row-input {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label {
  font-size: 28rpx;
  color: #374151;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.input {
  flex: 1;
  border: 2rpx solid #e5e7eb;
  border-radius: 10rpx;
  padding: 16rpx 18rpx;
  font-size: 28rpx;
  background: #f9fafb;
}

.mini-btn {
  background: #7c3aed;
  color: #fff;
  font-size: 26rpx;
  padding: 14rpx 22rpx;
  border-radius: 10rpx;
  margin-left: 12rpx;
  font-weight: 600;
}

.ghost-btn {
  background: #f3f4f6;
  color: #374151;
  font-size: 26rpx;
  padding: 12rpx 18rpx;
  border-radius: 10rpx;
  font-weight: 600;
}

.btn {
  border-radius: 12rpx;
  padding: 22rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  width: 100%;
  box-sizing: border-box;
  margin-top: 4rpx;
}

.btn::after { border: none; }

.btn-primary {
  background: #7c3aed;
  color: #fff;
}

.btn-secondary {
  background: #f3f4f6;
  color: #374151;
}

.toolbar {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  margin-bottom: 12rpx;
}

.search {
  flex: 1;
  border: 2rpx solid #e5e7eb;
  border-radius: 10rpx;
  padding: 14rpx 18rpx;
  font-size: 26rpx;
  background: #f9fafb;
}

.sort-btn {
  background: #f3f4f6;
  color: #374151;
  font-size: 24rpx;
  padding: 14rpx 18rpx;
  border-radius: 10rpx;
  margin-left: 10rpx;
  font-weight: 600;
}

.hint-empty {
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 26rpx;
  color: #9ca3af;
  line-height: 1.6;
  margin-top: 12rpx;
}

.friend-row {
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 14rpx;
  padding: 20rpx 22rpx;
  margin-top: 12rpx;
}

.friend-top {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 6rpx;
}

.friend-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #1f2937;
}

.friend-summary {
  font-size: 24rpx;
  color: #6b7280;
}

.friend-note {
  font-size: 24rpx;
  color: #9ca3af;
  display: block;
  margin: 6rpx 0 12rpx;
  line-height: 1.5;
}

.friend-actions {
  display: flex;
  margin-top: 8rpx;
}

.action-btn {
  flex: 1;
  font-size: 24rpx;
  font-weight: 600;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 8rpx;
  margin-right: 8rpx;
}

.action-btn:last-child {
  margin-right: 0;
}

.action-btn.primary {
  background: #7c3aed;
  color: #fff;
}

.action-btn.ghost {
  background: #fff;
  color: #374151;
  border: 2rpx solid #e5e7eb;
}

.action-btn.danger {
  background: #fef2f2;
  color: #ef4444;
}
