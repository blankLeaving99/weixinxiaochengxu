<view class="page-wrap">

  <!-- AI提供商选择 -->
  <view class="card">
    <text class="card-title">🤖 选择AI服务</text>

    <view class="provider-select">
      <text class="field-label">AI 提供商</text>
      <picker bindchange="onProviderChange" value="{{providerIdx}}" range="{{providerNames}}">
        <view class="picker-btn">
          <view class="picker-left">
            <text class="picker-text">{{providerNames[providerIdx]}}</text>
            <text class="free-tag" wx:if="{{isFree}}">免费</text>
          </view>
          <text class="picker-arrow">▾</text>
        </view>
      </picker>
      <text class="provider-hint">{{providerDesc}}</text>
    </view>

    <!-- 百度需要两个Key -->
    <view class="api-key-section" wx:if="{{showSecretKey}}">
      <text class="field-label">API Key</text>
      <input class="input-field" placeholder="百度 API Key" value="{{apiKey}}" bindinput="onApiKeyInput" />
      <text class="field-label">Secret Key</text>
      <input class="input-field" placeholder="百度 Secret Key" value="{{secretKey}}" bindinput="onSecretKeyInput" />
      <button class="save-btn" bindtap="saveKeys">保存</button>
      <text class="help-text">获取地址：console.bce.baidu.com/qianfan</text>
    </view>

    <!-- 其他只需要一个Key -->
    <view class="api-key-section" wx:else>
      <text class="field-label">API Key</text>
      <view class="input-row">
        <input class="input-field" placeholder="输入你的 API Key" password="true" value="{{apiKey}}" bindinput="onApiKeyInput" />
        <button class="save-btn" bindtap="saveKeys">保存</button>
      </view>
      <text class="help-text">获取地址：{{providerName}} 开放平台</text>
    </view>
  </view>

  <view wx:if="{{!canRun}}" class="blocker">
    <text class="blocker-icon">💬</text>
    <text class="blocker-text">{{blocker}}</text>
  </view>

  <block wx:else>
    <view class="card">
      <text class="card-title">💬 让 AI 给你写一份专属解读</text>
      <text class="card-sub">使用 {{providerName}} 生成你的性格分析报告</text>

      <button class="btn btn-primary" bindtap="generate" disabled="{{running}}">{{btnLabel}}</button>

      <view class="text-card" wx:if="{{text}}">
        <text class="text-body" selectable="true" user-select="true">{{text}}</text>
      </view>

      <button class="btn btn-secondary" wx:if="{{text !== '（点击下方按钮开始）'}}" bindtap="copyText">📋 复制解读</button>
    </view>
  </block>

  <!-- 使用说明 -->
  <view class="card tips-card">
    <text class="card-title">💡 白嫖指南</text>
    <view class="tip-item">
      <text class="tip-num">1</text>
      <text class="tip-text">去百度智能云注册账号（有百度账号即可）</text>
    </view>
    <view class="tip-item">
      <text class="tip-num">2</text>
      <text class="tip-text">进入千帆大模型平台，创建应用获取 API Key</text>
    </view>
    <view class="tip-item">
      <text class="tip-num">3</text>
      <text class="tip-text">复制 API Key 和 Secret Key 粘贴到上方</text>
    </view>
    <view class="tip-item">
      <text class="tip-num">4</text>
      <text class="tip-text">ERNIE-Speed-8K 模型完全免费，随便用！</text>
    </view>
  </view>

</view>
