<view class="page-wrap">

  <!-- 模式切换 -->
  <view class="mode-toggle" wx:if="{{canRun}}">
    <view class="mode-btn {{!isChatMode ? 'active' : ''}}" bindtap="switchMode" data-mode="analysis">
      📊 一键分析
    </view>
    <view class="mode-btn {{isChatMode ? 'active' : ''}}" bindtap="switchMode" data-mode="chat">
      💬 AI 对话
    </view>
  </view>

  <view wx:if="{{!canRun}}" class="blocker">
    <text class="blocker-icon">💬</text>
    <text class="blocker-text">{{blocker}}</text>
  </view>

  <!-- 一键分析模式 -->
  <block wx:elif="{{!isChatMode}}">
    <view class="card">
      <text class="card-title">📊 一键性格分析</text>
      <text class="card-sub">{{useCloud ? '使用云端 AI 为你生成专属分析' : '基于你的测试数据生成分析'}}</text>

      <button class="btn btn-primary" bindtap="generate" disabled="{{running}}">{{btnLabel}}</button>

      <view class="text-card" wx:if="{{text !== '（点击下方按钮开始）'}}">
        <text class="text-body" selectable="true" user-select="true">{{text}}</text>
      </view>

      <button class="btn btn-secondary" wx:if="{{text !== '（点击下方按钮开始）'}}" bindtap="copyText">📋 复制分析</button>
    </view>

    <view class="card tips-card">
      <text class="card-title">💡 说明</text>
      <view class="tip-item" wx:if="{{useCloud}}">
        <text class="tip-num">✓</text>
        <text class="tip-text">已接入云端 AI，可直接使用，无需配置</text>
      </view>
      <view class="tip-item">
        <text class="tip-num">{{useCloud ? '2' : '1'}}</text>
        <text class="tip-text">分析基于你的 MBTI、口味、星座、恋爱测试结果</text>
      </view>
      <view class="tip-item">
        <text class="tip-num">{{useCloud ? '3' : '2'}}</text>
        <text class="tip-text">完成更多测试可获得更完整的分析</text>
      </view>
    </view>
  </block>

  <!-- AI 对话模式 -->
  <block wx:else>
    <view class="card chat-card">
      <text class="card-title">💬 和 AI 聊聊你的性格</text>
      <text class="card-sub">{{useCloud ? '云端 AI 实时回复' : '本地分析模式'}}</text>

      <!-- 聊天消息列表 -->
      <scroll-view class="chat-messages" scroll-y="true" scroll-into-view="{{chatScrollId}}">
        <view class="chat-welcome" wx:if="{{chatMessages.length === 0}}">
          <text class="welcome-text">👋 你好！我是你的性格分析助手。</text>
          <text class="welcome-hint">你可以问我关于性格、人际关系、职业发展等问题～</text>
        </view>
        <view wx:for="{{chatMessages}}" wx:key="index" id="msg-{{index}}" class="chat-msg {{item.role === 'user' ? 'msg-user' : 'msg-ai'}}">
          <text class="msg-role">{{item.role === 'user' ? '🧑 我' : '🤖 AI'}}</text>
          <text class="msg-content" selectable="true" user-select="true">{{item.content}}</text>
        </view>
        <view wx:if="{{running}}" class="chat-msg msg-ai" id="msg-loading">
          <text class="msg-role">🤖 AI</text>
          <text class="msg-content typing">思考中…</text>
        </view>
        <view id="chat-bottom" style="height: 1rpx;"></view>
      </scroll-view>

      <!-- 输入框 -->
      <view class="chat-input-row">
        <input class="chat-input" placeholder="问我任何关于性格的问题…" value="{{userInput}}" bindinput="onChatInput" bindconfirm="sendMessage" confirm-type="send" />
        <view class="send-btn" style="background: {{themeColor}}" bindtap="sendMessage">发送</view>
      </view>
    </view>
  </block>

</view>
