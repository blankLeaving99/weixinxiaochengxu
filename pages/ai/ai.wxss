.page-wrap {
  background: #f3f4f6;
  min-height: 100vh;
  padding: 24rpx 24rpx 60rpx;
  box-sizing: border-box;
}

/* 模式切换 */
.mode-toggle {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.mode-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #6b7280;
  transition: all 0.3s;
}

.mode-btn.active {
  background: #7c3aed;
  color: #fff;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1f2937;
  display: block;
  margin-bottom: 8rpx;
}

.card-sub {
  font-size: 26rpx;
  color: #6b7280;
  display: block;
  margin-bottom: 20rpx;
}

/* 阻塞提示 */
.blocker {
  background: #fff;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.blocker-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.blocker-text {
  font-size: 28rpx;
  color: #6b7280;
  display: block;
  line-height: 1.7;
  white-space: pre-line;
}

/* 按钮 */
.btn {
  border-radius: 14rpx;
  padding: 26rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 16rpx;
}

.btn::after { border: none; }
.btn[disabled] { opacity: 0.6; }

.btn-primary {
  background: #7c3aed;
  color: #fff;
}

.btn-primary:active {
  background: #6d28d9;
}

.btn-secondary {
  background: #f3f4f6;
  color: #374151;
}

/* 文本卡片 */
.text-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 16rpx;
  min-height: 300rpx;
  border: 2rpx solid #e5e7eb;
}

.text-body {
  font-size: 28rpx;
  color: #1f2937;
  line-height: 1.85;
  display: block;
  white-space: pre-wrap;
}

/* 使用说明 */
.tips-card {
  background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%);
}

.tip-item {
  display: flex;
  align-items: flex-start;
  margin-top: 16rpx;
}

.tip-num {
  width: 40rpx;
  height: 40rpx;
  background: #10b981;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: bold;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.6;
  flex: 1;
}

/* 聊天模式 */
.chat-card {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  height: 80vh;
}

.chat-messages {
  flex: 1;
  overflow-y: auto;
  margin: 16rpx 0;
  min-height: 400rpx;
}

.chat-welcome {
  text-align: center;
  padding: 60rpx 20rpx;
}

.welcome-text {
  font-size: 32rpx;
  color: #1f2937;
  display: block;
  margin-bottom: 12rpx;
  font-weight: 600;
}

.welcome-hint {
  font-size: 26rpx;
  color: #9ca3af;
  display: block;
}

.chat-msg {
  margin-bottom: 20rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  max-width: 85%;
}

.msg-user {
  background: #7c3aed;
  color: #fff;
  margin-left: auto;
  border-bottom-right-radius: 4rpx;
}

.msg-ai {
  background: #f3f4f6;
  color: #1f2937;
  margin-right: auto;
  border-bottom-left-radius: 4rpx;
}

.msg-role {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  margin-bottom: 6rpx;
}

.msg-ai .msg-role {
  color: #9ca3af;
}

.msg-content {
  font-size: 28rpx;
  line-height: 1.7;
  display: block;
  white-space: pre-wrap;
  word-break: break-all;
}

.typing {
  color: #9ca3af;
}

/* 输入框 */
.chat-input-row {
  display: flex;
  gap: 12rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #f3f4f6;
}

.chat-input {
  flex: 1;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  background: #f9fafb;
}

.send-btn {
  color: #fff;
  font-size: 28rpx;
  padding: 18rpx 32rpx;
  border-radius: 12rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.send-btn:active {
  opacity: 0.8;
}
