.page-wrap {
  background: #f3f4f6;
  min-height: 100vh;
  padding: 24rpx 24rpx 60rpx;
  box-sizing: border-box;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1f2937;
  display: block;
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 24rpx;
  color: #6b7280;
  display: block;
  margin-bottom: 24rpx;
}

.card-sub {
  font-size: 26rpx;
  color: #6b7280;
  display: block;
  margin-bottom: 20rpx;
}

/* 提供商选择 */
.provider-select {
  margin-bottom: 24rpx;
}

.field-label {
  font-size: 26rpx;
  color: #374151;
  font-weight: 500;
  display: block;
  margin-bottom: 10rpx;
  margin-top: 16rpx;
}

.field-label:first-child {
  margin-top: 0;
}

.picker-btn {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.picker-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.picker-text {
  font-size: 28rpx;
  color: #1f2937;
}

.free-tag {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: bold;
}

.picker-arrow {
  font-size: 24rpx;
  color: #9ca3af;
}

.provider-hint {
  font-size: 22rpx;
  color: #10b981;
  display: block;
  margin-top: 8rpx;
}

/* API Key 输入 */
.api-key-section {
  margin-top: 20rpx;
}

.input-row {
  display: flex;
  gap: 12rpx;
}

.input-field {
  width: 100%;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  background: #fff;
  box-sizing: border-box;
  margin-bottom: 12rpx;
}

.save-btn {
  background: #7c3aed;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx 32rpx;
  font-size: 26rpx;
  font-weight: 500;
  margin-top: 8rpx;
}

.save-btn::after { border: none; }

.help-text {
  font-size: 22rpx;
  color: #9ca3af;
  display: block;
  margin-top: 8rpx;
}

/* 阻塞提示 */
.blocker {
  background: #fff;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.blocker-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.blocker-text {
  font-size: 28rpx;
  color: #6b7280;
  display: block;
  line-height: 1.7;
  white-space: pre-line;
}

/* 按钮 */
.btn {
  border-radius: 14rpx;
  padding: 26rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 16rpx;
}

.btn::after { border: none; }
.btn[disabled] { opacity: 0.6; }

.btn-primary {
  background: #7c3aed;
  color: #fff;
}

.btn-primary:active {
  background: #6d28d9;
}

.btn-secondary {
  background: #f3f4f6;
  color: #374151;
}

/* 文本卡片 */
.text-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 16rpx;
  min-height: 300rpx;
  border: 2rpx solid #e5e7eb;
}

.text-body {
  font-size: 28rpx;
  color: #1f2937;
  line-height: 1.85;
  display: block;
  white-space: pre-wrap;
}

/* 使用说明 */
.tips-card {
  background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%);
}

.tip-item {
  display: flex;
  align-items: flex-start;
  margin-top: 16rpx;
}

.tip-num {
  width: 40rpx;
  height: 40rpx;
  background: #10b981;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: bold;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.6;
  flex: 1;
}
