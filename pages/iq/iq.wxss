.page-wrap {
  min-height: 100vh;
  background: #f3f4f6;
  padding: 24rpx;
  box-sizing: border-box;
}

/* 介绍页 */
.intro-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.intro-emoji {
  font-size: 120rpx;
  display: block;
  margin-bottom: 20rpx;
}

.intro-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1f2937;
  display: block;
  margin-bottom: 12rpx;
}

.intro-desc {
  font-size: 28rpx;
  color: #6b7280;
  display: block;
  margin-bottom: 40rpx;
}

.intro-features {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-bottom: 40rpx;
}

.intro-feature {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.feature-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.feature-text {
  font-size: 24rpx;
  color: #6b7280;
}

/* 答题页 */
.progress-wrap {
  background: #e5e7eb;
  border-radius: 10rpx;
  height: 12rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.progress-bar {
  background: linear-gradient(90deg, #6366f1, #8b5cf6);
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.3s;
}

.quiz-count {
  font-size: 24rpx;
  color: #9ca3af;
  display: block;
  text-align: center;
  margin-bottom: 24rpx;
}

.question-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.question-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #1f2937;
  line-height: 1.6;
  display: block;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s;
}

.option-item:active {
  transform: scale(0.98);
}

.option-item.correct {
  background: #ecfdf5;
  border: 2rpx solid #10b981;
}

.option-item.wrong {
  background: #fef2f2;
  border: 2rpx solid #ef4444;
}

.option-letter {
  width: 48rpx;
  height: 48rpx;
  background: #6366f1;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.option-text {
  font-size: 28rpx;
  color: #374151;
  flex: 1;
}

.option-icon {
  font-size: 32rpx;
  color: #10b981;
  font-weight: bold;
}

.wrong-icon {
  color: #ef4444;
}

/* 结果页 */
.result-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.result-emoji {
  font-size: 100rpx;
  display: block;
  margin-bottom: 16rpx;
}

.result-level {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 30rpx;
}

.iq-circle {
  width: 200rpx;
  height: 200rpx;
  border: 10rpx solid;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20rpx;
}

.iq-num {
  font-size: 64rpx;
  font-weight: bold;
  color: #1f2937;
  display: block;
}

.iq-label {
  font-size: 28rpx;
  color: #9ca3af;
  display: block;
}

.result-stat {
  font-size: 28rpx;
  color: #6b7280;
  display: block;
  margin-bottom: 20rpx;
}

.result-desc {
  font-size: 28rpx;
  color: #374151;
  line-height: 1.8;
  display: block;
}

.btn-group {
  margin-top: 30rpx;
}

.btn {
  border-radius: 16rpx;
  padding: 26rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 16rpx;
}

.btn::after { border: none; }

.btn-primary {
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: #fff;
}

.btn-secondary {
  background: #f3f4f6;
  color: #374151;
}
