<view class="page-wrap">

  <!-- 选择模式 -->
  <view wx:if="{{phase === 'choose'}}">
    <view class="card">
      <text class="page-title">💕 恋爱默契大挑战</text>
      <text class="page-subtitle">两位玩家各答 12 道题目，测测你们的默契度~</text>
    </view>
    <view class="card mode-card" bindtap="chooseLocal">
      <text class="mode-emoji">📱</text>
      <view class="mode-text">
        <text class="mode-title">把手机交给对方</text>
        <text class="mode-desc">两人在同一部手机上轮流答题</text>
      </view>
      <text class="mode-arrow">›</text>
    </view>
    <view class="card mode-card" bindtap="chooseRemote">
      <text class="mode-emoji">💌</text>
      <view class="mode-text">
        <text class="mode-title">发送给好友</text>
        <text class="mode-desc">邀请好友在各自手机上答题</text>
      </view>
      <text class="mode-arrow">›</text>
    </view>

    <!-- 历史挑战记录 -->
    <view wx:if="{{historyList.length > 0}}" class="card">
      <text class="section-title">📋 历史挑战记录</text>
      <view wx:for="{{historyList}}" wx:key="id" class="history-item" data-id="{{item.id}}" bindtap="viewChallengeDetail">
        <view class="history-top">
          <text class="history-names">{{item.from_nickname}} ❤ {{item.to_nickname}}</text>
          <text class="history-score" style="color: {{item.scoreColor}}">{{item.score}}%</text>
        </view>
        <view class="history-bottom">
          <text class="history-date">{{item.date}}</text>
          <text class="history-detail-btn">查看详情 ›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 选择好友（远程模式） -->
  <view wx:elif="{{phase === 'selectFriend'}}">
    <view class="card">
      <text class="page-title">选择挑战好友</text>
      <text class="page-subtitle">选择一位好友发送挑战邀请</text>
    </view>
    <view wx:if="{{friendList.length === 0}}" class="card">
      <text class="empty-hint">暂无好友，请先添加好友</text>
    </view>
    <view
      wx:for="{{friendList}}"
      wx:key="id"
      class="card friend-item"
      data-id="{{item.id}}"
      data-name="{{item.name}}"
      bindtap="selectFriend"
    >
      <text class="friend-name">👤 {{item.name}}</text>
      <text class="mode-arrow">›</text>
    </view>
    <button class="btn btn-outline" bindtap="goBack">返回</button>
  </view>

  <!-- 本地模式：输入昵称 -->
  <view wx:elif="{{phase === 'setup'}}">
    <view class="card">
      <text class="page-title">💕 恋爱默契大挑战</text>
      <text class="page-subtitle">规则：两位玩家依次作答 12 道题目，对方作答时请勿偷看哦~</text>
    </view>
    <view class="card">
      <text class="input-label">玩家 A 昵称</text>
      <input class="input-field" placeholder="小明" value="{{playerAName}}" bindinput="onNameAInput" />
      <text class="input-label">玩家 B 昵称</text>
      <input class="input-field" placeholder="小红" value="{{playerBName}}" bindinput="onNameBInput" />
      <button class="btn btn-pink" bindtap="startChallenge">开始挑战 💕</button>
    </view>
  </view>

  <!-- 等待对方答题（远程模式） -->
  <view wx:elif="{{phase === 'waiting'}}">
    <view class="card">
      <view class="handoff-box">
        <text class="handoff-emoji">⏳</text>
        <text class="handoff-msg">{{waitingMsg}}</text>
        <text class="handoff-hint">对方答完后你将自动看到结果</text>
      </view>
    </view>
    <button class="btn btn-outline" bindtap="finish">返回首页</button>
  </view>

  <!-- 交接阶段（本地模式） -->
  <view wx:elif="{{phase === 'handoff'}}">
    <view class="card">
      <view class="handoff-box">
        <text class="handoff-emoji">📱</text>
        <text class="handoff-msg">{{handoffMsg}}</text>
        <text class="handoff-hint">另一位玩家请暂时回避，准备好后再点击下方按钮</text>
      </view>
      <button class="btn btn-pink" bindtap="readyToAnswer">我准备好了 ✓</button>
    </view>
  </view>

  <!-- 答题阶段 -->
  <view wx:elif="{{phase === 'question'}}">
    <view class="card">
      <text class="q-player">{{qProgress}}</text>
      <text class="q-text">{{qText}}</text>
    </view>
    <view
      class="opt-item"
      wx:for="{{options}}"
      wx:key="index"
      bindtap="chooseOption"
      data-index="{{index}}"
    >
      <text class="opt-text">{{item}}</text>
    </view>
  </view>

  <!-- 结果阶段 -->
  <view wx:elif="{{phase === 'result'}}">
    <view class="card result-card">
      <text class="result-names">{{playerAName}} ❤ {{playerBName}}</text>
      <text class="result-score-big">{{score}}%</text>
      <text class="result-match-label">匹配题数：{{matchCount}} / 12</text>
      <view class="divider"></view>
      <text class="result-comment">{{comment}}</text>
    </view>
    <button class="btn btn-pink" bindtap="finish">完成，回到主页</button>
  </view>

  <!-- 答案详情 -->
  <view wx:elif="{{phase === 'detail'}}">
    <view class="card result-card">
      <text class="result-names">{{detailFrom}} ❤ {{detailTo}}</text>
      <text class="result-score-big">{{detailScore}}%</text>
      <text class="result-comment">{{detailComment}}</text>
    </view>

    <!-- 授权开关 -->
    <view class="card">
      <view class="share-row">
        <view class="share-left">
          <text class="share-icon">🔓</text>
          <view class="share-text">
            <text class="share-title">允许对方查看我的答案</text>
            <text class="share-desc">开启后对方可以看到你的每题选择</text>
          </view>
        </view>
        <switch checked="{{myShare}}" color="#ec4899" bindchange="toggleShare" />
      </view>
    </view>

    <!-- 我的答案 -->
    <view wx:if="{{myAnswers.length > 0}}" class="card">
      <text class="section-title">📝 我的答案</text>
      <view wx:for="{{myAnswers}}" wx:key="index" class="answer-item">
        <text class="answer-q">{{index + 1}}. {{item.question}}</text>
        <text class="answer-a">我选：{{item.myChoice}}</text>
      </view>
    </view>

    <!-- 对方的答案（需要授权） -->
    <view wx:if="{{theirAnswers.length > 0}}" class="card">
      <text class="section-title">💕 对方的答案</text>
      <view wx:for="{{theirAnswers}}" wx:key="index" class="answer-item">
        <text class="answer-q">{{index + 1}}. {{item.question}}</text>
        <text class="answer-a" style="color: {{item.same ? '#10b981' : '#9ca3af'}}">
          对方选：{{item.theirChoice}} {{item.same ? '✓ 一致' : ''}}
        </text>
      </view>
    </view>
    <view wx:elif="{{!theirShareAllowed}}" class="card">
      <text class="share-hint">🔒 对方尚未授权查看答案</text>
    </view>

    <button class="btn btn-outline" bindtap="goBack">返回</button>
  </view>

</view>
