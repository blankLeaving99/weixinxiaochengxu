.page-wrap {
  background: #f3f4f6;
  min-height: 100vh;
  padding: 24rpx 24rpx 60rpx;
  box-sizing: border-box;
}

/* 模式选择卡片 */
.mode-card {
  display: flex;
  align-items: center;
  padding: 32rpx;
}

.mode-card:active {
  background: #fdf2f8;
}

.mode-emoji {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.mode-text {
  flex: 1;
}

.mode-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1f2937;
  display: block;
}

.mode-desc {
  font-size: 24rpx;
  color: #9ca3af;
  display: block;
  margin-top: 4rpx;
}

.mode-arrow {
  font-size: 36rpx;
  color: #d1d5db;
}

/* 好友列表 */
.friend-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
}

.friend-item:active {
  background: #fdf2f8;
}

.friend-name {
  flex: 1;
  font-size: 30rpx;
  color: #1f2937;
}

.empty-hint {
  text-align: center;
  color: #9ca3af;
  font-size: 28rpx;
  padding: 40rpx;
}

/* 返回按钮 */
.btn-outline {
  background: #fff;
  color: #374151;
  border: 2rpx solid #e5e7eb;
  margin-top: 16rpx;
}

/* 历史记录 */
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1f2937;
  display: block;
  margin-bottom: 16rpx;
}

.history-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.history-item:last-child {
  border-bottom: none;
}

.history-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.history-names {
  font-size: 28rpx;
  color: #374151;
}

.history-score {
  font-size: 32rpx;
  font-weight: bold;
}

.history-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 4rpx;
}

.history-date {
  font-size: 22rpx;
  color: #9ca3af;
}

.history-detail-btn {
  font-size: 24rpx;
  color: #ec4899;
}

/* 答案详情 */
.share-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.share-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.share-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.share-text {
  flex: 1;
}

.share-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1f2937;
  display: block;
}

.share-desc {
  font-size: 22rpx;
  color: #9ca3af;
  display: block;
}

.share-hint {
  text-align: center;
  color: #9ca3af;
  font-size: 28rpx;
  padding: 20rpx;
}

.answer-item {
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.answer-item:last-child {
  border-bottom: none;
}

.answer-q {
  font-size: 26rpx;
  color: #374151;
  display: block;
  margin-bottom: 4rpx;
}

.answer-a {
  font-size: 24rpx;
  color: #6b7280;
  display: block;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.06);
}

.page-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #1f2937;
  display: block;
  margin-bottom: 12rpx;
}

.page-subtitle {
  font-size: 28rpx;
  color: #6b7280;
  line-height: 1.6;
  display: block;
}

.input-label {
  font-size: 28rpx;
  color: #374151;
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}

.input-field {
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 24rpx;
  background: #fafafa;
  height: 88rpx;
  line-height: 88rpx;
}

/* 交接提示 */
.handoff-box {
  background: #fff0f6;
  border: 2rpx solid #fce7f3;
  border-radius: 16rpx;
  padding: 36rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.handoff-emoji {
  font-size: 72rpx;
  display: block;
  margin-bottom: 16rpx;
}

.handoff-msg {
  font-size: 34rpx;
  font-weight: bold;
  color: #be185d;
  display: block;
  margin-bottom: 12rpx;
}

.handoff-hint {
  font-size: 26rpx;
  color: #ec4899;
  display: block;
}

/* 答题 */
.q-player {
  font-size: 26rpx;
  color: #9ca3af;
  display: block;
  margin-bottom: 14rpx;
  font-weight: 500;
}

.q-text {
  font-size: 34rpx;
  font-weight: bold;
  color: #1f2937;
  display: block;
  line-height: 1.5;
}

.opt-item {
  background: #fff;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.04);
}

.opt-item:active {
  background: #fff0f6;
  border-color: #ec4899;
}

.opt-text {
  font-size: 30rpx;
  color: #1f2937;
  line-height: 1.5;
  display: block;
}

/* 结果 */
.result-card {
  text-align: center;
  padding: 40rpx 32rpx;
}

.result-names {
  font-size: 36rpx;
  font-weight: bold;
  color: #1f2937;
  display: block;
  margin-bottom: 8rpx;
}

.result-score-big {
  font-size: 110rpx;
  font-weight: bold;
  color: #ec4899;
  display: block;
  padding: 10rpx 0;
}

.result-match-label {
  font-size: 28rpx;
  color: #9ca3af;
  display: block;
  margin-bottom: 8rpx;
}

.divider {
  height: 1rpx;
  background: #f3f4f6;
  margin: 24rpx 0;
}

.result-comment {
  font-size: 34rpx;
  font-weight: bold;
  color: #ec4899;
  display: block;
}

/* 按钮 */
.btn {
  display: block;
  border-radius: 14rpx;
  padding: 26rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 8rpx;
  border: none;
  line-height: 1.4;
  width: 100%;
  box-sizing: border-box;
}

.btn::after {
  border: none;
}

.btn-pink {
  background: #ec4899;
  color: #fff;
}
