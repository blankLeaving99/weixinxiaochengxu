.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #7c3aed 0%, #a855f7 40%, #f3f4f6 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx;
}

/* 顶部 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
  margin-bottom: 80rpx;
}

.logo-circle {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.logo-emoji {
  font-size: 80rpx;
}

.app-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
}

.app-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 功能介绍 */
.features {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 36rpx;
  margin-bottom: 80rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.feature-item + .feature-item {
  border-top: 1rpx solid #f3f4f6;
}

.feature-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
}

.feature-text {
  font-size: 30rpx;
  color: #374151;
}

/* 登录按钮 */
.login-area {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-btn {
  width: 100% !important;
  height: 96rpx;
  line-height: 96rpx;
  background: #7c3aed;
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(124, 58, 237, 0.4);
}

.login-btn::after {
  border: none;
}

.login-btn[disabled] {
  background: #a78bfa;
  color: #fff;
}

.login-hint {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 24rpx;
}

/* 底部 */
.footer {
  position: fixed;
  bottom: 60rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #d1d5db;
}
