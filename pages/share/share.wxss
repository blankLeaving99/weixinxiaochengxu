.page-wrap {
  background: #f3f4f6;
  min-height: 100vh;
  padding: 24rpx 24rpx 60rpx;
  box-sizing: border-box;
}

.head {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 1rpx 8rpx rgba(0, 0, 0, 0.04);
}

.head-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #7c3aed;
  display: block;
}

.head-sub {
  font-size: 26rpx;
  color: #6b7280;
  display: block;
  margin-top: 6rpx;
}

.empty {
  background: #fff;
  border-radius: 14rpx;
  padding: 80rpx 30rpx;
  text-align: center;
  font-size: 28rpx;
  color: #9ca3af;
}

.card-row {
  background: #fff;
  border-radius: 14rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.04);
}

.card-icon {
  font-size: 48rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.card-info {
  flex: 1;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 4rpx;
}

.card-summary {
  font-size: 24rpx;
  color: #6b7280;
  display: block;
}

.gen-btn {
  color: #fff;
  font-size: 26rpx;
  padding: 14rpx 24rpx;
  border-radius: 10rpx;
  font-weight: 600;
}

.modal {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.75);
  z-index: 1000;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.modal-inner {
  background: transparent;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.preview {
  width: 100%;
  max-width: 600rpx;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.4);
}

.modal-actions {
  display: flex;
  margin-top: 24rpx;
  width: 100%;
  max-width: 600rpx;
}

.modal-btn {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  padding: 22rpx;
  border-radius: 12rpx;
  margin: 0 8rpx;
}

.modal-btn.primary {
  background: #7c3aed;
  color: #fff;
}

.modal-btn.ghost {
  background: #fff;
  color: #374151;
}

.modal-tip {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 14rpx;
  text-align: center;
}
