<view class="page-wrap">

  <!-- 顶部统计 -->
  <view class="header-card" style="background: {{themeColor}}">
    <view class="header-top">
      <view class="streak-wrap">
        <text class="streak-icon">🔥</text>
        <text class="streak-num">{{streak}}</text>
        <text class="streak-label">天连续打卡</text>
      </view>
      <view class="level-badge">
        <text class="level-icon">{{levelIcon}}</text>
        <text class="level-text">Lv.{{level}}</text>
      </view>
    </view>
    <text class="header-date">{{today}}</text>
  </view>

  <!-- 每日运势 -->
  <view class="card fortune-card">
    <view class="fortune-header">
      <text class="card-title">🔮 今日运势</text>
      <text class="fortune-level" style="color: {{fortune.level === '大吉' ? '#ef4444' : fortune.level === '中吉' ? '#f59e0b' : '#10b981'}}">{{fortune.level}}</text>
    </view>
    <text class="fortune-emoji">{{fortune.emoji}}</text>
    <text class="fortune-desc">{{fortune.desc}}</text>
    <view class="fortune-lucky">
      <view class="lucky-item">
        <text class="lucky-label">幸运色</text>
        <text class="lucky-value">{{fortune.lucky[0]}}</text>
      </view>
      <view class="lucky-item">
        <text class="lucky-label">幸运数</text>
        <text class="lucky-value">{{fortune.lucky[1]}}</text>
      </view>
      <view class="lucky-item">
        <text class="lucky-label">吉方位</text>
        <text class="lucky-value">{{fortune.lucky[2]}}</text>
      </view>
    </view>
  </view>

  <!-- 每日名言 -->
  <view class="card quote-card">
    <text class="quote-mark">"</text>
    <text class="quote-text">{{quote.text}}</text>
    <text class="quote-author">—— {{quote.author}}</text>
  </view>

  <!-- 每日挑战 -->
  <view class="card challenge-card">
    <text class="card-title">🎯 今日挑战</text>
    <view class="challenge-content">
      <text class="challenge-icon">{{challenge.icon}}</text>
      <view class="challenge-info">
        <text class="challenge-name">{{challenge.title}}</text>
        <text class="challenge-desc">{{challenge.desc}}</text>
        <text class="challenge-reward">奖励：+{{challenge.points}} XP</text>
      </view>
    </view>
    <button wx:if="{{!challengeDone}}" class="btn btn-challenge" bindtap="completeChallenge">✅ 完成挑战</button>
    <view wx:else class="challenge-done">
      <text class="done-text">✅ 今日挑战已完成</text>
    </view>
  </view>

  <!-- 每日一题 -->
  <view class="card question-card">
    <text class="card-title">📝 每日一题</text>
    <text class="question-text">{{question}}</text>

    <view wx:if="{{!doneToday}}" class="answer-section">
      <textarea class="answer-input" placeholder="写下你的答案..." value="{{input}}" bindinput="onInput" maxlength="200" />
      <text class="char-count">{{input.length}}/200</text>
      <button class="btn btn-primary" bindtap="checkin">🔥 打卡 +10XP</button>
    </view>

    <view wx:else class="done-section">
      <view class="done-banner">
        <text class="done-icon">✅</text>
        <text class="done-msg">今日已打卡</text>
      </view>
      <view class="my-answer">
        <text class="answer-label">我的回答：</text>
        <text class="answer-text">{{answer}}</text>
      </view>
    </view>
  </view>

  <!-- 打卡日历 -->
  <view class="card calendar-card" bindtap="toggleCalendar">
    <view class="calendar-header">
      <text class="card-title">📅 打卡日历</text>
      <text class="calendar-toggle">{{showCalendar ? '收起' : '展开'}}</text>
    </view>
    <view wx:if="{{showCalendar}}" class="calendar-body">
      <view class="weekday-row">
        <text class="weekday" wx:for="{{['日','一','二','三','四','五','六']}}" wx:key="*this">{{item}}</text>
      </view>
      <view class="days-grid">
        <view class="day-item {{item.isToday ? 'today' : ''}} {{item.checked ? 'checked' : ''}}" wx:for="{{calendarDays}}" wx:key="date">
          <text class="day-text">{{item.day}}</text>
          <text wx:if="{{item.checked}}" class="check-mark">✓</text>
        </view>
      </view>
    </view>
  </view>

</view>
