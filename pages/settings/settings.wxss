.page-wrap {
  background: #f3f4f6;
  min-height: 100vh;
  padding: 0 0 60rpx;
  box-sizing: border-box;
}

/* 用户信息卡片 */
.profile-card {
  padding: 60rpx 32rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-wrap {
  margin-bottom: 20rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.avatar-text {
  font-size: 56rpx;
  color: #fff;
  font-weight: bold;
}

.profile-info {
  text-align: center;
  margin-bottom: 30rpx;
}

.profile-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.profile-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  display: block;
  margin-top: 8rpx;
}

.level-tag {
  display: inline-flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  padding: 6rpx 16rpx;
  margin-top: 12rpx;
}

.level-tag-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.level-tag-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: bold;
}

.profile-stats {
  display: flex;
  width: 100%;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 20rpx 0;
}

.profile-stat {
  flex: 1;
  text-align: center;
  border-right: 1rpx solid rgba(255, 255, 255, 0.2);
}

.profile-stat:last-child {
  border-right: none;
}

.profile-stat-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.profile-stat-lbl {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  margin-top: 4rpx;
}

/* 菜单区域 */
.menu-section {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.menu-section-title {
  font-size: 24rpx;
  color: #9ca3af;
  padding: 20rpx 28rpx 8rpx;
  display: block;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f9fafb;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #374151;
}

.menu-input {
  flex: 1;
  font-size: 28rpx;
  color: #374151;
  text-align: right;
}

.menu-value {
  font-size: 26rpx;
  color: #9ca3af;
}

.menu-arrow {
  font-size: 32rpx;
  color: #d1d5db;
  margin-left: 10rpx;
}

.menu-danger {
  color: #ef4444;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.mini-btn {
  color: #fff;
  border: none;
  border-radius: 8rpx;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

/* 主题选择网格 */
.theme-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx 20rpx 24rpx;
  gap: 16rpx;
}

.theme-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: calc(25% - 12rpx);
  padding: 16rpx 0;
  border-radius: 12rpx;
  border: 3rpx solid transparent;
  transition: all 0.2s;
}

.theme-item:active {
  transform: scale(0.95);
}

.theme-active {
  border-color: var(--theme-color, #7c3aed);
  background: #f9fafb;
}

.theme-circle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  margin-bottom: 8rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.theme-active .theme-circle {
  box-shadow: 0 0 0 4rpx rgba(255, 255, 255, 0.8), 0 0 0 6rpx currentColor;
}

.theme-name {
  font-size: 22rpx;
  color: #6b7280;
  text-align: center;
}

.theme-active .theme-name {
  color: #374151;
  font-weight: 600;
}

.mini-btn::after { border: none; }

/* 底部信息 */
.footer-info {
  text-align: center;
  padding: 30rpx 24rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #9ca3af;
  display: block;
  line-height: 1.6;
}
