<view class="page-wrap">

  <!-- 用户信息卡片 -->
  <view class="profile-card" style="background: {{currentColor}}">
    <view class="avatar-wrap">
      <view class="avatar">
        <text class="avatar-text">{{profileName ? profileName[0] : '我'}}</text>
      </view>
    </view>
    <view class="profile-info">
      <text class="profile-name">{{profileName || '点击设置昵称'}}</text>
      <text class="profile-id">ID: {{userId}}</text>
      <view class="level-tag">
        <text class="level-tag-icon">{{levelIcon}}</text>
        <text class="level-tag-text">Lv.{{level}} {{levelTitle}}</text>
      </view>
    </view>
    <view class="profile-stats">
      <view class="profile-stat">
        <text class="profile-stat-num">{{totalXp}}</text>
        <text class="profile-stat-lbl">积分</text>
      </view>
      <view class="profile-stat">
        <text class="profile-stat-num">{{doneCount}}</text>
        <text class="profile-stat-lbl">测试</text>
      </view>
      <view class="profile-stat">
        <text class="profile-stat-num">{{achCount}}</text>
        <text class="profile-stat-lbl">成就</text>
      </view>
      <view class="profile-stat">
        <text class="profile-stat-num">{{friendCount}}</text>
        <text class="profile-stat-lbl">好友</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <text class="menu-section-title">个人中心</text>
    <view class="menu-item" bindtap="goToPage" data-page="/pages/history/history">
      <text class="menu-icon">📈</text>
      <text class="menu-text">成长档案</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToPage" data-page="/pages/achievements/achievements">
      <text class="menu-icon">🏆</text>
      <text class="menu-text">成就墙</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToPage" data-page="/pages/friends/friends">
      <text class="menu-icon">👥</text>
      <text class="menu-text">好友管理</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToPage" data-page="/pages/ranking/ranking">
      <text class="menu-icon">📊</text>
      <text class="menu-text">排行榜</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToPage" data-page="/pages/ai/ai">
      <text class="menu-icon">💬</text>
      <text class="menu-text">AI 解读设置</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-section">
    <text class="menu-section-title">主题颜色</text>
    <view class="theme-grid">
      <view
        class="theme-item {{currentTheme === item.key ? 'theme-active' : ''}}"
        wx:for="{{themes}}"
        wx:key="key"
        data-key="{{item.key}}"
        bindtap="onThemeTap"
      >
        <view class="theme-circle" style="background: {{item.color}}"></view>
        <text class="theme-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <view class="menu-section">
    <text class="menu-section-title">个人设置</text>
    <view class="menu-item">
      <text class="menu-icon">🪪</text>
      <text class="menu-text">昵称</text>
      <view class="input-row">
        <input class="menu-input" placeholder="请输入昵称" value="{{profileName}}" bindinput="onNameInput" />
        <button class="mini-btn" style="background: {{currentColor}}" bindtap="saveName">保存</button>
      </view>
    </view>
    <view class="menu-item" bindtap="toggleDiscoverable">
      <text class="menu-icon">🔍</text>
      <text class="menu-text">允许被搜索</text>
      <view class="menu-right">
        <text class="menu-hint">{{discoverable ? '开启' : '关闭'}}</text>
        <switch checked="{{discoverable}}" color="{{currentColor}}" />
      </view>
    </view>
  </view>

  <view class="menu-section">
    <text class="menu-section-title">数据管理</text>
    <view class="menu-item" bindtap="backup">
      <text class="menu-icon">📤</text>
      <text class="menu-text">备份数据</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="restore">
      <text class="menu-icon">📥</text>
      <text class="menu-text">恢复数据</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="clearAll">
      <text class="menu-icon">⚠️</text>
      <text class="menu-text menu-danger">清除全部数据</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="footer-info">
    <text class="footer-text">数据保存在微信小程序本地存储中</text>
    <text class="footer-text">卸载小程序会清空所有数据</text>
  </view>

</view>
