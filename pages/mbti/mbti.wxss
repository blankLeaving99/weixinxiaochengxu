.page-wrap {
  background: #f3f4f6;
  min-height: 100vh;
  padding: 24rpx 24rpx 60rpx;
  box-sizing: border-box;
}

.progress-wrap {
  background: #e5e7eb;
  border-radius: 8rpx;
  height: 10rpx;
  margin-bottom: 28rpx;
  overflow: hidden;
}

.progress-bar {
  background: #2563eb;
  height: 10rpx;
  border-radius: 8rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.06);
}

.q-num {
  font-size: 26rpx;
  color: #9ca3af;
  display: block;
  margin-bottom: 14rpx;
  font-weight: 500;
}

.q-text {
  font-size: 34rpx;
  font-weight: bold;
  color: #1f2937;
  display: block;
  line-height: 1.5;
}

.opt-item {
  background: #fff;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.04);
}

.opt-item:active {
  background: #eff6ff;
  border-color: #2563eb;
}

.opt-text {
  font-size: 30rpx;
  color: #1f2937;
  line-height: 1.5;
  display: block;
}

/* 结果 */
.result-card {
  padding: 40rpx 32rpx;
}

.result-type {
  font-size: 72rpx;
  font-weight: bold;
  color: #2563eb;
  display: block;
  margin: 10rpx 0 4rpx;
  letter-spacing: 8rpx;
}

.result-nick {
  font-size: 38rpx;
  font-weight: 600;
  color: #1f2937;
  display: block;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #2563eb;
  letter-spacing: 2rpx;
  display: block;
  margin-bottom: 12rpx;
  text-transform: uppercase;
}

.result-desc {
  font-size: 29rpx;
  color: #374151;
  line-height: 1.7;
  display: block;
}

.result-meta {
  font-size: 28rpx;
  color: #6b7280;
  display: block;
  font-family: monospace;
  letter-spacing: 2rpx;
}

.divider {
  height: 1rpx;
  background: #f3f4f6;
  margin: 24rpx 0;
}

.btn {
  display: block;
  border-radius: 14rpx;
  padding: 26rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 16rpx;
  border: none;
  line-height: 1.4;
  width: 100%;
  box-sizing: border-box;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: #2563eb;
  color: #fff;
}
