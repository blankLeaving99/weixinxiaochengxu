.page-wrap {
  min-height: 100vh;
  background: #f3f4f6;
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1f2937;
  display: block;
  margin-bottom: 16rpx;
}

.card-date {
  font-size: 24rpx;
  color: #9ca3af;
  display: block;
  margin-top: -12rpx;
  margin-bottom: 16rpx;
}

/* 心情选择器 */
.mood-selector {
  display: flex;
  justify-content: space-around;
  margin-bottom: 24rpx;
}

.mood-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.mood-option.selected {
  background: #f3e8ff;
  transform: scale(1.1);
}

.mood-emoji {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.mood-label {
  font-size: 22rpx;
  color: #6b7280;
}

.mood-option.selected .mood-label {
  color: #7c3aed;
  font-weight: bold;
}

/* 标签选择 */
.section-label {
  font-size: 24rpx;
  color: #6b7280;
  display: block;
  margin-bottom: 12rpx;
}

.tags-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.tag-item {
  background: #f3f4f6;
  border-radius: 20rpx;
  padding: 8rpx 20rpx;
  border: 2rpx solid transparent;
}

.tag-item.selected {
  background: #ede9fe;
  border-color: #7c3aed;
}

.tag-text {
  font-size: 24rpx;
  color: #374151;
}

.tag-item.selected .tag-text {
  color: #7c3aed;
  font-weight: bold;
}

/* 备注输入 */
.note-section {
  margin-bottom: 20rpx;
}

.note-input {
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
  min-height: 120rpx;
}

/* 今日已记录 */
.today-card {
  background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%);
}

.today-mood {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.today-emoji {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.today-label {
  font-size: 32rpx;
  font-weight: bold;
  color: #10b981;
}

.today-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.today-tags .tag-item {
  background: rgba(255, 255, 255, 0.7);
}

.today-note {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.6;
  display: block;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 12rpx;
  padding: 16rpx;
}

/* 本周心情 */
.week-chart {
  display: flex;
  justify-content: space-around;
}

.week-day {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.week-emoji {
  font-size: 40rpx;
  margin-bottom: 8rpx;
  min-height: 48rpx;
}

.week-label {
  font-size: 22rpx;
  color: #6b7280;
}

.week-label.today {
  color: #7c3aed;
  font-weight: bold;
}

/* 本月热力图 */
.month-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
  margin-bottom: 16rpx;
}

.month-day {
  width: 13%;
  aspect-ratio: 1;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.month-day-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: bold;
}

.month-legend {
  display: flex;
  justify-content: center;
  gap: 16rpx;
}

.legend-item {
  display: flex;
  align-items: center;
}

.legend-color {
  width: 20rpx;
  height: 20rpx;
  border-radius: 4rpx;
  margin-right: 6rpx;
}

.legend-text {
  font-size: 20rpx;
  color: #6b7280;
}

/* 统计 */
.stats-grid {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.stat-item {
  flex: 1;
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 16rpx;
  text-align: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #7c3aed;
  display: block;
}

.stat-label {
  font-size: 22rpx;
  color: #6b7280;
  display: block;
  margin-top: 4rpx;
}

.top-tags {
  padding-top: 16rpx;
  border-top: 2rpx solid #f3f4f6;
}

.top-tags-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.top-tag-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.top-tag-name {
  font-size: 26rpx;
  color: #374151;
}

.top-tag-count {
  font-size: 24rpx;
  color: #9ca3af;
}

/* 历史记录 */
.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.history-toggle {
  font-size: 24rpx;
  color: #7c3aed;
}

.history-list {
  margin-top: 16rpx;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.history-item:last-child {
  border-bottom: none;
}

.history-left {
  flex: 1;
}

.history-date {
  font-size: 26rpx;
  color: #374151;
  display: block;
  margin-bottom: 8rpx;
}

.history-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.history-tag {
  background: #f3f4f6;
  border-radius: 12rpx;
  padding: 4rpx 12rpx;
  font-size: 20rpx;
  color: #6b7280;
}

.history-mood {
  font-size: 36rpx;
  margin-left: 16rpx;
}

.empty-history {
  text-align: center;
  padding: 20rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #9ca3af;
}

/* 按钮 */
.btn {
  border-radius: 16rpx;
  padding: 26rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  width: 100%;
  box-sizing: border-box;
}

.btn::after { border: none; }

.btn-primary {
  background: linear-gradient(135deg, #7c3aed, #5b21b6);
  color: #fff;
}
