/* 挑战通知 */
.challenge-notice {
  background: linear-gradient(135deg, #fce7f3, #f5d0fe);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #f9a8d4;
}

.notice-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #be185d;
  margin-bottom: 16rpx;
  display: block;
}

.notice-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 8rpx;
}

.notice-item:last-child {
  margin-bottom: 0;
}

.notice-content {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.notice-dismiss {
  font-size: 28rpx;
  color: #9ca3af;
  padding: 0 8rpx;
  margin-left: 12rpx;
}

.notice-text {
  font-size: 28rpx;
  color: #374151;
}

.notice-btn {
  font-size: 28rpx;
  color: #ec4899;
  font-weight: bold;
}

.header {
  padding: 36rpx 32rpx 50rpx;
}

.header-inner {
  display: flex;
  align-items: center;
}

.header-emoji {
  font-size: 68rpx;
  margin-right: 22rpx;
}

.header-title {
  font-size: 42rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.header-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  display: block;
  margin-top: 4rpx;
}

.page-wrap {
  padding: 0 20rpx 60rpx;
  background: #f3f4f6;
  min-height: 100vh;
  box-sizing: border-box;
  margin-top: -20rpx;
}

/* 轮播图 */
.banner-swiper {
  height: 280rpx;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.12);
}

.banner-item {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.banner-content {
  display: flex;
  align-items: center;
}

.banner-icon {
  font-size: 80rpx;
  margin-right: 30rpx;
}

.banner-text {
  flex: 1;
}

.banner-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.banner-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
  margin-top: 8rpx;
}

/* 等级卡片 */
.level-card {
  background: linear-gradient(135deg, #f59e0b 0%, #f97316 100%);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 20rpx rgba(245, 158, 11, 0.3);
}

.level-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.level-icon {
  font-size: 56rpx;
  margin-right: 20rpx;
}

.level-info {
  flex: 1;
}

.level-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 10rpx;
}

.xp-bar-wrap {
  background: rgba(255, 255, 255, 0.3);
  border-radius: 10rpx;
  height: 14rpx;
  overflow: hidden;
  margin-bottom: 6rpx;
}

.xp-bar {
  background: #fff;
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.5s ease;
}

.xp-text {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
}

.level-right {
  text-align: center;
  margin-left: 20rpx;
}

.total-xp {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.total-xp-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
}

/* 统计行 */
.stat-row {
  background: #fff;
  border-radius: 16rpx;
  padding: 22rpx 0;
  margin-bottom: 16rpx;
  display: flex;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.stat-item {
  flex: 1;
  text-align: center;
  border-right: 1rpx solid #f3f4f6;
}

.stat-item:last-child { border-right: none; }

.stat-num {
  font-size: 30rpx;
  font-weight: bold;
  color: #7c3aed;
  display: block;
}

.stat-lbl {
  font-size: 22rpx;
  color: #9ca3af;
  display: block;
  margin-top: 4rpx;
}

/* 区块标题 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 8rpx 12rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
  display: block;
}

.section-more {
  font-size: 24rpx;
  color: #7c3aed;
  display: block;
}

/* 网格布局 */
.grid-wrap {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-wrap: wrap;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.grid-item {
  width: 25%;
  text-align: center;
  padding: 16rpx 0;
  box-sizing: border-box;
}

.grid-item:active {
  opacity: 0.7;
}

.grid-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 10rpx;
}

.grid-icon {
  font-size: 48rpx;
}

.grid-label {
  font-size: 22rpx;
  color: #374151;
  display: block;
}

/* 测试卡片 */
.test-card {
  background: #fff;
  border-radius: 18rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.card-top {
  display: flex;
  align-items: flex-start;
  margin-bottom: 14rpx;
}

.card-icon {
  font-size: 52rpx;
  margin-right: 20rpx;
  line-height: 1.2;
  flex-shrink: 0;
}

.card-meta {
  flex: 1;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
}

.card-status {
  font-size: 24rpx;
  font-weight: 600;
  margin-top: 6rpx;
  display: block;
}

.card-desc {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.55;
  margin-bottom: 16rpx;
  display: block;
}

.summary-box {
  background: #f9fafb;
  border-radius: 10rpx;
  padding: 14rpx 18rpx;
  margin-bottom: 16rpx;
  border-left: 4rpx solid #e5e7eb;
}

.summary-text {
  font-size: 26rpx;
  color: #374151;
}

.action-bar {
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
}

.action-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
}

.footer-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 8rpx 20rpx;
}

.footer-hint {
  font-size: 24rpx;
  color: #9ca3af;
}

.footer-danger {
  font-size: 24rpx;
  color: #ef4444;
}
